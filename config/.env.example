# ============================================================
# SAPL → ClickUp  |  Câmara Municipal de Bayeux
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env em repositório público
# ============================================================

# --- SAPL ---
SAPL_BASE_URL=https://sapl.bayeux.pb.leg.br

# --- ClickUp ---
CLICKUP_API_KEY=pk_XXXXXXXXXXXXXXXXXXXXXXXX
CLICKUP_TEAM_ID=              # ID do workspace (obter via script setup)

# IDs das Lists no ClickUp (preenchidos após rodar setup_clickup.py)
LIST_SECRETARIA=
LIST_COMISSOES=
LIST_PROCURADORIA=
LIST_GABINETES=
LIST_MESA_DIRETORA=
LIST_EXECUTIVO=

# --- Alertas (opcional) ---
# Para alertas por e-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app

# Para alertas via Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Configurações gerais ---
# Quantos dias antes do prazo alertar (separados por vírgula)
ALERTAR_DIAS_ANTES=7,3,1
# Intervalo entre sincronizações em minutos
SYNC_INTERVAL_MINUTES=30
